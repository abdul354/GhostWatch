# Example environment variables for GhostWatch local development
# Copy to `.env` and fill in real values if you want live data access.

# Copernicus Marine credentials (optional — used to fetch surface currents)
COPERNICUS_USERNAME=""
COPERNICUS_PASSWORD=""

# Global Fishing Watch API token (optional — used when `use_mock=false`)
GFW_API_TOKEN=""

# Local dev notes
# - If you leave these blank, the backend will fall back to deterministic mock data.
# - Keep your real credentials out of the repository. Add `.env` to .gitignore (already excluded).