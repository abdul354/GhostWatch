# Example environment variables for GhostWatch local development.
# Copy this file to `.env` and fill real values only if you want live data.

# Copernicus Marine credentials (optional; used to fetch surface currents)
COPERNICUS_USERNAME=""
COPERNICUS_PASSWORD=""

# Global Fishing Watch API token (optional; used when `use_mock=false`)
GFW_API_TOKEN=""

# Azure AI Foundry model deployment (optional)
# Leave these blank for local deterministic fallback mode.
AZURE_AI_FOUNDRY_ENDPOINT=""
AZURE_AI_FOUNDRY_DEPLOYMENT=""
AZURE_AI_FOUNDRY_API_VERSION=""
AZURE_AI_FOUNDRY_API_KEY=""

# Local dev notes:
# - If these are blank, GhostWatch still runs with deterministic mock data.
# - Keep real credentials out of the repository. `.env` is ignored by git.
